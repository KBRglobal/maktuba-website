---
const { lang = "he" } = Astro.props;
const t = {
  he: { readings: "קריאות", academy: "אקדמיה", pricing: "מחירים", about: "אודות", app: "האפליקציה" },
  en: { readings: "Readings", academy: "Academy", pricing: "Pricing", about: "About", app: "App" },
  ar: { readings: "قراءات",   academy: "الأكاديمية", pricing: "الأسعار", about: "عن", app: "التطبيق" },
}[lang as "he" | "en" | "ar"];
const prefix = lang === "he" ? "" : `/${lang}`;
const pathNoLang = Astro.url.pathname.replace(/^\/(en|ar)/, "") || "/";

// Wordmark per language — Hebrew with niqqud, Arabic with tashkīl, Latin tracked
const wordmark = { he: "מַכְתּוּבָה", en: "Maktuba", ar: "مَكْتُوبَة" }[lang as "he" | "en" | "ar"];
const wmStyle = lang === "en"
  ? "font-family: 'Playfair Display', serif; font-weight: 700; letter-spacing: 0.28em; text-transform: uppercase;"
  : "font-family: 'Frank Ruhl Libre', 'David', serif; font-weight: 900; letter-spacing: 0.01em;";
const wmSize = lang === "en" ? "text-[18px]" : "text-[22px]";
---
<header class="sticky top-0 inset-x-0 z-40 backdrop-blur-md border-b border-border/60" style="background: rgba(10,6,18,0.75);">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href={`${prefix}/`} class="flex items-center gap-3" aria-label="Maktuba — Home">
      <img src="https://cdn.maktuba.app/brand/mark-256.webp?v=2" alt="" width="32" height="32" class="block" loading="eager" decoding="async" />
      <span class={`font-display ${wmSize} text-gold`} style={wmStyle}>
        {wordmark}
      </span>
    </a>
    <div class="flex items-center gap-1 sm:gap-6">
      <a href={`${prefix}/#readings`} class="hidden sm:inline text-[13px] tracking-[0.15em] uppercase text-parchment-2/85 hover:text-gold transition">{t.readings}</a>
      <a href={`${prefix}/academy`}    class="text-[13px] tracking-[0.15em] uppercase text-parchment-2/85 hover:text-gold transition">{t.academy}</a>
      <a href={`${prefix}/#pricing`}  class="hidden sm:inline text-[13px] tracking-[0.15em] uppercase text-parchment-2/85 hover:text-gold transition">{t.pricing}</a>
      <div class="flex items-center text-[11px] tracking-widest ms-2 sm:ms-4">
        <a href={pathNoLang} class:list={["px-2 py-1 transition", lang === "he" ? "text-gold" : "text-muted hover:text-gold"]} aria-label="עברית">HE</a>
        <span class="text-border/80">·</span>
        <a href={`/en${pathNoLang === "/" ? "" : pathNoLang}`} class:list={["px-2 py-1 transition", lang === "en" ? "text-gold" : "text-muted hover:text-gold"]}>EN</a>
        <span class="text-border/80">·</span>
        <a href={`/ar${pathNoLang === "/" ? "" : pathNoLang}`} class:list={["px-2 py-1 transition", lang === "ar" ? "text-gold" : "text-muted hover:text-gold"]}>AR</a>
      </div>
    </div>
  </nav>
</header>
