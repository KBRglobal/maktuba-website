---
const { lang = "he" } = Astro.props;
---
<header class="sticky top-0 inset-x-0 z-40 backdrop-blur-md border-b border-border/60" style="background: rgba(10,6,18,0.75);">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3" aria-label="מכתובה — דף הבית">
      <img src="https://cdn.maktuba.app/brand/mark-256.webp?v=2" alt="" width="32" height="32" class="block" loading="eager" decoding="async" />
      <span class="text-[22px] text-gold" style="font-family: 'Frank Ruhl Libre', 'David', serif; font-weight: 900; letter-spacing: 0.01em;">
        מַכְתּוּבָה
      </span>
    </a>
    <div class="flex items-center gap-4 sm:gap-6">
      <a href="/academy" class="hidden sm:inline text-[13px] tracking-[0.12em] hover:text-gold transition" style="color: rgba(235,227,211,0.7);">אקדמיה</a>
      <a href="#" class="text-[13px] tracking-[0.12em] px-4 py-2 rounded-full transition" style="color: #0a0612; background: linear-gradient(135deg, #f1d694, #d4a574 60%, #b8860b); font-family: 'Frank Ruhl Libre', serif; font-weight: 700;">
        הורדת האפליקציה
      </a>
    </div>
  </nav>
</header>
