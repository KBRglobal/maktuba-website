---
const CDN = "https://cdn.maktuba.app";
const mark = `${CDN}/brand/mark-512.webp?v=2`;
---
<section class="final-cta">
  <div class="cta-halo" aria-hidden="true"></div>

  <div class="cta-inner">
    <img src={mark} alt="" class="cta-mark" width="84" height="84" />
    <h2 class="cta-h2">החדר פתוח.</h2>
    <p class="cta-sub">מה שנכתב — כבר כתוב. בואו נקרא אותו יחד.</p>

    <div class="cta-badges">
      <a href="https://apps.apple.com/app/maktuba" class="cta-badge cta-badge-primary" aria-label="הורדה ב-App Store">
        <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor" aria-hidden="true">
          <path d="M17.05 12.04c-.03-2.86 2.34-4.24 2.45-4.31-1.34-1.96-3.42-2.23-4.16-2.26-1.77-.18-3.46 1.04-4.36 1.04-.91 0-2.29-1.02-3.77-.99-1.94.03-3.74 1.13-4.74 2.86-2.02 3.51-.51 8.69 1.45 11.53.96 1.39 2.09 2.95 3.58 2.9 1.44-.06 1.98-.93 3.71-.93 1.73 0 2.22.93 3.74.9 1.55-.03 2.52-1.42 3.46-2.81 1.1-1.62 1.55-3.19 1.57-3.27-.03-.01-3.01-1.16-3.04-4.59zm-2.85-8.42C15-1 16.04-.07 16.36-.05c-.07.79-.62 1.95-1.41 2.93-.71.86-1.74 1.59-2.76 1.51-.13-.78.34-1.96.99-2.77z"/>
        </svg>
        <div class="cta-badge-text">
          <span class="cta-badge-sub">זמינה ב־</span>
          <span class="cta-badge-name">App Store</span>
        </div>
      </a>
      <a href="https://play.google.com/store/apps/details?id=app.maktuba" class="cta-badge cta-badge-primary" aria-label="הורדה ב-Google Play">
        <svg viewBox="0 0 24 24" width="28" height="28" aria-hidden="true">
          <path d="M3.6 1.7c-.3.3-.5.8-.5 1.4v18c0 .6.2 1.1.5 1.4l.1.1L13.8 12.1v-.2L3.7 1.7l-.1.1z" fill="currentColor" opacity="0.85"/>
          <path d="M17.2 15.5l-3.4-3.4v-.2l3.4-3.4.1.1 4 2.3c1.2.7 1.2 1.8 0 2.4l-4 2.2z" fill="currentColor"/>
          <path d="M17.3 15.4L13.8 12 3.6 22.3c.4.4 1.1.5 1.8.1l11.9-7z" fill="currentColor" opacity="0.7"/>
          <path d="M17.3 8.7l-11.9-7c-.7-.4-1.4-.4-1.8.1L13.8 12l3.5-3.3z" fill="currentColor" opacity="0.55"/>
        </svg>
        <div class="cta-badge-text">
          <span class="cta-badge-sub">זמינה ב־</span>
          <span class="cta-badge-name">Google Play</span>
        </div>
      </a>
    </div>

    <p class="cta-micro">50 מפתחות מתנה · ללא כרטיס אשראי · ללא מנוי</p>
  </div>
</section>

<style>
  .final-cta {
    position: relative;
    padding: clamp(6rem, 12vw, 9rem) clamp(1.5rem, 5vw, 4rem);
    background: var(--void);
    overflow: hidden;
    text-align: center;
  }
  .cta-halo {
    position: absolute;
    top: 50%; left: 50%;
    width: 800px; height: 800px;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle at center, rgba(212,165,116,0.08), transparent 60%);
    pointer-events: none;
    z-index: 0;
  }
  .cta-inner {
    position: relative; z-index: 1;
    max-width: 720px;
    margin: 0 auto;
  }
  .cta-mark {
    display: block;
    margin: 0 auto 1.6rem;
    border-radius: 14px;
    filter: drop-shadow(0 0 30px rgba(212,165,116,0.3));
  }
  .cta-h2 {
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 900;
    font-size: clamp(2.6rem, 7vw, 4.4rem);
    line-height: 1.1;
    color: var(--gold);
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
    text-shadow: 0 0 60px rgba(212,165,116,0.2);
  }
  .cta-sub {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: clamp(1.2rem, 2.5vw, 1.6rem);
    color: var(--gold-light);
    margin-bottom: 2.5rem;
    line-height: 1.5;
  }

  .cta-badges {
    display: flex; flex-wrap: wrap; justify-content: center;
    gap: 0.9rem;
    margin-bottom: 1.6rem;
  }
  .cta-badge {
    display: inline-flex; align-items: center; gap: 14px;
    padding: 14px 26px 14px 22px;
    background: rgba(212,165,116,0.06);
    border: 1px solid rgba(212,165,116,0.3);
    border-radius: 16px;
    color: var(--parchment);
    text-decoration: none;
    transition: background 280ms cubic-bezier(0.22,1,0.36,1),
                border-color 280ms cubic-bezier(0.22,1,0.36,1),
                transform 240ms cubic-bezier(0.22,1,0.36,1),
                box-shadow 280ms cubic-bezier(0.22,1,0.36,1);
  }
  .cta-badge:hover {
    background: rgba(212,165,116,0.12);
    border-color: rgba(212,165,116,0.55);
    transform: translateY(-2px);
    box-shadow: 0 10px 40px rgba(212,165,116,0.15);
  }
  .cta-badge-text { display: flex; flex-direction: column; line-height: 1.1; text-align: right; }
  .cta-badge-sub {
    font-family: 'Heebo', sans-serif;
    font-size: 0.66rem;
    color: rgba(235,227,211,0.6);
    margin-bottom: 2px;
    letter-spacing: 0.04em;
  }
  .cta-badge-name {
    font-family: 'Heebo', sans-serif;
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--parchment);
  }

  .cta-micro {
    font-family: 'Heebo', sans-serif;
    font-size: 0.78rem;
    color: var(--muted);
    letter-spacing: 0.08em;
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-badge { transition: none; }
  }
</style>
