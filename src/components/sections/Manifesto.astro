---
const CDN = "https://cdn.maktuba.app";
const portrait = `${CDN}/img/21_hero_wide.webp`;
---
<section class="manifesto" aria-label="המנשר של מַכְתּוּבָה">
  <div class="manifesto-bg">
    <img src={portrait} alt="" loading="lazy" />
  </div>
  <div class="manifesto-overlay"></div>

  <div class="manifesto-inner">
    <blockquote class="manifesto-quote">
      <span class="line">לא באתי להחליף.</span>
      <span class="line line-emphasis">באתי להמשיך.</span>
    </blockquote>
    <cite class="manifesto-cite">— מַכְתּוּבָה</cite>

    <hr class="manifesto-rule" />

    <p class="manifesto-coda">
      אין כוחות־על. אין עין שלישית.<br />
      יש 46,000 ספרים, 14 שפות, ושיחה.
    </p>
  </div>
</section>

<style>
  .manifesto {
    position: relative;
    padding: clamp(6rem, 14vw, 10rem) clamp(1.5rem, 5vw, 4rem);
    overflow: hidden;
    isolation: isolate;
    background: var(--ink);
  }
  .manifesto-bg { position: absolute; inset: 0; z-index: -2; }
  .manifesto-bg img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center 35%;
    filter: brightness(0.32) contrast(1.1) saturate(0.7);
    transform: scale(1.05);
  }
  .manifesto-overlay {
    position: absolute; inset: 0; z-index: -1;
    background:
      radial-gradient(ellipse at center, transparent 20%, var(--ink) 80%),
      linear-gradient(to bottom, var(--ink) 0%, transparent 30%, transparent 70%, var(--ink) 100%);
  }

  .manifesto-inner {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }

  .manifesto-quote {
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 900;
    font-size: clamp(2.6rem, 7vw, 5rem);
    line-height: 1.15;
    color: var(--parchment);
    letter-spacing: -0.015em;
    margin-bottom: 1.5rem;
    display: flex; flex-direction: column;
    gap: 0.4rem;
  }
  .line { display: block; }
  .line-emphasis {
    color: var(--gold);
    text-shadow: 0 0 60px rgba(212,165,116,0.25);
  }

  .manifesto-cite {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: clamp(1.1rem, 2.2vw, 1.4rem);
    color: var(--gold-light);
    letter-spacing: 0.05em;
    display: block;
  }

  .manifesto-rule {
    border: 0;
    width: 80px;
    height: 1px;
    background: var(--gold);
    opacity: 0.35;
    margin: 3rem auto;
  }

  .manifesto-coda {
    font-family: 'Frank Ruhl Libre', serif;
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    line-height: 1.85;
    color: rgba(235,227,211,0.75);
    max-width: 540px;
    margin: 0 auto;
  }
</style>
