---
import Kicker from "./Kicker.astro";
import Icon from "../Icon.astro";

const faqs = [
  { q: "האם זה באמת AI?",                a: "כן. אני מודל שלמד מ־46,000 ספרים ב־14 שפות. אין קסם. יש למידה." },
  { q: "מה קורה למידע שלי?",             a: "לא נשמר. לא מועבר. כל קריאה — בחדר שלנו בלבד." },
  { q: "כמה זה עולה?",                    a: "הקריאה הראשונה — אצלי. אחר כך: מפתחות. לא מנוי. לא חוזר. את משלמת רק על מה שאת רוצה לקרוא." },
  { q: "באילו שפות?",                     a: "עברית, אנגלית, ערבית. בעברית עם ניקוד מלא היכן שצריך." },
  { q: "iPhone או Android?",              a: "שניהם. App Store ו־Google Play." },
  { q: "האם אתם מחליפים מטפלים?",        a: "לא. אני סבתא, לא רופאה. לדברים רציניים — כדאי לפנות לאדם שמכיר אתכם." },
];
---
<section class="faq">
  <div class="faq-inner">
    <header class="faq-head">
      <Kicker eyebrow="שאלות שחוזרות" />
      <h2 class="faq-h2">מה שואלים אותי</h2>
    </header>

    <div class="faq-list">
      {faqs.map((f) => (
        <details class="faq-item">
          <summary class="faq-q">
            <span class="faq-q-text">{f.q}</span>
            <span class="faq-q-icon" aria-hidden="true">
              <Icon name="arrow-down" size={20} stroke="var(--gold)" />
            </span>
          </summary>
          <div class="faq-a">{f.a}</div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq {
    padding: clamp(5rem, 10vw, 8rem) clamp(1.5rem, 5vw, 4rem);
    background: var(--ink);
  }
  .faq-inner { max-width: 820px; margin: 0 auto; }
  .faq-head { text-align: center; margin-bottom: clamp(2.5rem, 5vw, 4rem); }
  .faq-h2 {
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 700;
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    color: var(--parchment);
    letter-spacing: -0.01em;
  }

  .faq-list {
    border-top: 1px solid rgba(212,165,116,0.1);
  }
  .faq-item {
    border-bottom: 1px solid rgba(212,165,116,0.1);
  }
  .faq-q {
    display: flex; align-items: center; justify-content: space-between;
    gap: 1rem;
    padding: 1.6rem 0.4rem;
    cursor: pointer;
    list-style: none;
    transition: color 240ms cubic-bezier(0.22,1,0.36,1);
  }
  .faq-q::-webkit-details-marker { display: none; }
  .faq-q-text {
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 500;
    font-size: clamp(1.05rem, 2vw, 1.2rem);
    color: var(--parchment);
    flex: 1;
    text-align: right;
  }
  .faq-q-icon {
    display: inline-flex;
    transition: transform 280ms cubic-bezier(0.22,1,0.36,1);
    flex-shrink: 0;
  }
  .faq-item[open] .faq-q-text { color: var(--gold); }
  .faq-item[open] .faq-q-icon { transform: rotate(180deg); }

  .faq-a {
    padding: 0 0.4rem 1.6rem;
    font-family: 'Heebo', sans-serif;
    font-size: 0.98rem;
    line-height: 1.8;
    color: rgba(235,227,211,0.78);
    max-width: 680px;
  }

  .faq-q:hover .faq-q-text { color: var(--gold-light); }

  @media (prefers-reduced-motion: reduce) {
    .faq-q, .faq-q-icon { transition: none; }
  }
</style>
