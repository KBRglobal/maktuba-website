---
import Kicker from "./Kicker.astro";

const CDN = "https://cdn.maktuba.app";
const homeScreen = `${CDN}/img/A02_home_screen.webp`;

// Curated buzzword list — actual reading types across traditions.
// Source: academy course catalog + Maktuba reading library.
const groups = [
  {
    title: "טארוט",
    items: ["קלף בודד", "פריסת שלוש", "Celtic Cross", "פריסת אהבה", "פריסת קריירה", "פריסת ירח", "כן/לא", "קלף יומי"],
  },
  {
    title: "קריאה בקפה",
    items: ["דמויות בספל", "אותיות עבריות", "מספרים", "צמחים וחיות", "שביל הפרידה", "ספל הזוגיות", "ספל הילדים", "סימני שפע"],
  },
  {
    title: "כף יד",
    items: ["קו החיים", "קו הלב", "קו הראש", "קו הגורל", "הר ונוס", "הר מאדים", "הר ירח", "טבעת שלמה"],
  },
  {
    title: "אסטרולוגיה",
    items: ["מפת לידה", "טרנזיט יומי", "סינסטרי זוגי", "החזרי שמש", "פרוגרסיות", "מולד הירח", "מזל עולה", "פרצוף הבית השביעי"],
  },
  {
    title: "נומרולוגיה",
    items: ["מספר חיים", "מספר נשמה", "מספר ביטוי", "שנה אישית", "תאימות שמות", "מספר גורל", "פירמידת הפיתגוראס", "מספר מאסטר"],
  },
  {
    title: "קבלה",
    items: ["גימטריה אישית", "צירופי אותיות", "10 ספירות", "72 שמות", "ספר היצירה", "אילן הספירות", "תורת הסוד", "פרצופים"],
  },
  {
    title: "פתרון חלומות",
    items: ["חלום חוזר", "חלום בעלי חיים", "חלום מים", "חלום מתים", "חלום נפילה", "חלום טיסה", "חלום מספרים", "חלום אהבה"],
  },
  {
    title: "תהילים",
    items: ["מזמור לפי גיל", "מזמור לפי שם", "מזמור הגנה", "מזמור פרנסה", "מזמור זוגיות", "מזמור רפואה", "שבעה מזמורים", "פרק י״ט"],
  },
  {
    title: "אי צ׳ינג",
    items: ["שאלה פתוחה", "שאלת כן/לא", "הקסגרם היום", "מצב נוכחי", "התפתחות", "תשובה לשנה", "שאלה זוגית", "תשובה לבחירה"],
  },
  {
    title: "קריסטלים",
    items: ["אבן יומית", "אבן הגנה", "אבן אהבה", "אבן שפע", "אבן ריפוי", "צבע אישי", "צ׳אקרה דומיננטית", "ערכת שבע"],
  },
];

const totalReadings = groups.reduce((s, g) => s + g.items.length, 0);
---
<section class="readings">
  <div class="readings-bg-orb" aria-hidden="true"></div>

  <div class="readings-inner">
    <header class="readings-head">
      <Kicker eyebrow="כל מה שיש בחדר" />
      <h2 class="readings-h2">מאתיים ועוד.</h2>
      <p class="readings-sub">לא מאתיים כפתורים. מאתיים שאלות עתיקות שיש להן תשובה.</p>
    </header>

    <div class="readings-layout">
      <aside class="readings-side">
        <div class="readings-phone">
          <div class="phone-frame">
            <img src={homeScreen} alt="מַכְתּוּבָה — מסך הבית" loading="lazy" width="280" height="560" />
          </div>
          <div class="readings-phone-halo" aria-hidden="true"></div>
        </div>

        <dl class="readings-stats">
          <div class="stat-row">
            <dt>מסורות</dt>
            <dd>{groups.length}</dd>
          </div>
          <div class="stat-row">
            <dt>סוגי קריאות</dt>
            <dd>200+</dd>
          </div>
          <div class="stat-row">
            <dt>שיעורי אקדמיה</dt>
            <dd>194</dd>
          </div>
          <div class="stat-row">
            <dt>שפות</dt>
            <dd>3</dd>
          </div>
        </dl>
      </aside>

      <div class="readings-grid">
        {groups.map((g) => (
          <article class="reading-group">
            <h3 class="rg-title">
              <span class="rg-bullet" aria-hidden="true"></span>
              {g.title}
            </h3>
            <ul class="rg-pills">
              {g.items.map((item) => <li class="rg-pill">{item}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>

    <p class="readings-foot">— ועוד עשרות. בחדר שלי הספרים מסודרים אחרת.</p>
  </div>
</section>

<style>
  .readings {
    position: relative;
    padding: clamp(5rem, 10vw, 9rem) clamp(1.5rem, 5vw, 4rem);
    background: linear-gradient(180deg, var(--ink), var(--void));
    overflow: hidden;
    isolation: isolate;
  }
  .readings-bg-orb {
    position: absolute;
    bottom: -200px;
    left: -200px;
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(212,165,116,0.06), transparent 60%);
    pointer-events: none;
    z-index: -1;
  }
  .readings-inner { max-width: 1280px; margin: 0 auto; }

  .readings-head {
    text-align: center;
    max-width: 720px;
    margin: 0 auto clamp(3rem, 6vw, 4.5rem);
  }
  .readings-h2 {
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 900;
    font-size: clamp(2.6rem, 6vw, 4rem);
    line-height: 1.1;
    color: var(--gold);
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
    text-shadow: 0 0 60px rgba(212,165,116,0.18);
  }
  .readings-sub {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    color: rgba(235,227,211,0.78);
  }

  .readings-layout {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }

  /* Side column: phone + stats */
  .readings-side {
    position: sticky;
    top: 6rem;
    display: flex; flex-direction: column;
    gap: 2rem;
    align-items: center;
  }
  .readings-phone {
    position: relative;
    isolation: isolate;
  }
  .phone-frame {
    position: relative;
    width: 240px;
    background: #111;
    border-radius: 32px;
    padding: 11px;
    box-shadow:
      0 30px 80px rgba(0,0,0,0.6),
      0 0 0 1px rgba(255,255,255,0.06),
      0 0 50px rgba(212,165,116,0.08);
    z-index: 1;
  }
  .phone-frame::before {
    content: '';
    position: absolute;
    top: 9px; left: 50%; transform: translateX(-50%);
    width: 70px; height: 5px;
    background: #222;
    border-radius: 999px;
    z-index: 2;
  }
  .phone-frame img {
    width: 100%; height: auto;
    border-radius: 22px;
    display: block;
    aspect-ratio: 280/560;
    object-fit: cover;
  }
  .readings-phone-halo {
    position: absolute;
    inset: -30px;
    background: radial-gradient(ellipse at center, rgba(212,165,116,0.14), transparent 65%);
    z-index: -1;
  }

  .readings-stats {
    width: 100%;
    max-width: 240px;
    background: rgba(255,255,255,0.018);
    border: 1px solid rgba(212,165,116,0.12);
    border-radius: 14px;
    padding: 0.5rem 1.1rem;
  }
  .stat-row {
    display: flex; justify-content: space-between; align-items: baseline;
    padding: 0.85rem 0;
    border-bottom: 1px solid rgba(212,165,116,0.08);
  }
  .stat-row:last-child { border-bottom: 0; }
  .stat-row dt {
    font-family: 'Heebo', sans-serif;
    font-size: 0.78rem;
    color: rgba(235,227,211,0.65);
    letter-spacing: 0.04em;
  }
  .stat-row dd {
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 900;
    font-size: 1.4rem;
    color: var(--gold-hi);
    letter-spacing: -0.01em;
  }

  /* Grid of groups */
  .readings-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.2rem;
  }
  .reading-group {
    padding: 1.4rem 1.3rem;
    background: rgba(255,255,255,0.018);
    border: 1px solid rgba(212,165,116,0.1);
    border-radius: 14px;
    transition: border-color 280ms cubic-bezier(0.22,1,0.36,1);
  }
  .reading-group:hover { border-color: rgba(212,165,116,0.28); }
  .rg-title {
    display: flex; align-items: center; gap: 10px;
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--gold);
    margin-bottom: 0.9rem;
  }
  .rg-bullet {
    width: 6px; height: 6px;
    background: var(--gold);
    transform: rotate(45deg);
    opacity: 0.7;
  }
  .rg-pills {
    list-style: none;
    display: flex; flex-wrap: wrap;
    gap: 6px;
  }
  .rg-pill {
    display: inline-flex; align-items: center;
    padding: 5px 11px;
    background: rgba(212,165,116,0.05);
    border: 1px solid rgba(212,165,116,0.13);
    border-radius: 999px;
    font-family: 'Heebo', sans-serif;
    font-size: 0.74rem;
    font-weight: 400;
    color: rgba(235,227,211,0.78);
    letter-spacing: 0.01em;
    transition: background 240ms cubic-bezier(0.22,1,0.36,1),
                color 240ms cubic-bezier(0.22,1,0.36,1),
                border-color 240ms cubic-bezier(0.22,1,0.36,1);
    white-space: nowrap;
  }
  .rg-pill:hover {
    background: rgba(212,165,116,0.14);
    border-color: rgba(212,165,116,0.35);
    color: var(--gold-hi);
  }

  .readings-foot {
    text-align: center;
    margin-top: clamp(2.5rem, 5vw, 4rem);
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--muted);
  }

  @media (max-width: 1000px) {
    .readings-layout { grid-template-columns: 1fr; }
    .readings-side {
      position: static;
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      gap: 2rem;
    }
    .readings-stats { max-width: 320px; }
  }
  @media (max-width: 660px) {
    .readings-grid { grid-template-columns: 1fr; }
    .readings-side { flex-direction: column; }
  }

  @media (prefers-reduced-motion: reduce) {
    .reading-group, .rg-pill { transition: none; }
  }
</style>
