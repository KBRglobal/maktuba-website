---
const CDN = "https://cdn.maktuba.app";
const heroWide = `${CDN}/img/21_hero_wide.webp`;
const appHome  = `${CDN}/img/A02_home_screen.webp`;
const mark     = `${CDN}/brand/mark-512.webp?v=2`;
---
<section class="hero">
  <div class="hero-bg">
    <img src={heroWide} alt="" loading="eager" fetchpriority="high" />
  </div>
  <div class="hero-overlay"></div>

  <div class="hero-inner">
    <div class="hero-text">
      <img src={mark} alt="" class="hero-mark" width="96" height="96" />
      <h1 class="hero-title">מַכְתּוּבָה</h1>
      <p class="hero-tagline">מה שנכתב — כבר כתוב</p>
      <p class="hero-lead">קריאת קפה, טארוט, כף יד, אסטרולוגיה וקבלה — עם AI שלמד 46,000 ספרים ב-14 שפות.</p>

      <div class="hero-kpi" role="list">
        <div class="kpi" role="listitem">
          <span class="kpi-num">5.0</span>
          <span class="kpi-label">דירוג</span>
          <span class="kpi-stars">★★★★★</span>
        </div>
        <div class="kpi-sep"></div>
        <div class="kpi" role="listitem">
          <span class="kpi-num">200+</span>
          <span class="kpi-label">סוגי קריאות</span>
        </div>
        <div class="kpi-sep"></div>
        <div class="kpi" role="listitem">
          <span class="kpi-num">46K</span>
          <span class="kpi-label">ספרים נלמדו</span>
        </div>
      </div>

      <div class="hero-badges">
        <a href="https://apps.apple.com/app/maktuba" class="store-badge" aria-label="הורדה ב-App Store">
          <svg class="store-icon" viewBox="0 0 24 24" width="26" height="26" fill="currentColor" aria-hidden="true">
            <path d="M17.05 12.04c-.03-2.86 2.34-4.24 2.45-4.31-1.34-1.96-3.42-2.23-4.16-2.26-1.77-.18-3.46 1.04-4.36 1.04-.91 0-2.29-1.02-3.77-.99-1.94.03-3.74 1.13-4.74 2.86-2.02 3.51-.51 8.69 1.45 11.53.96 1.39 2.09 2.95 3.58 2.9 1.44-.06 1.98-.93 3.71-.93 1.73 0 2.22.93 3.74.9 1.55-.03 2.52-1.42 3.46-2.81 1.1-1.62 1.55-3.19 1.57-3.27-.03-.01-3.01-1.16-3.04-4.59zm-2.85-8.42C15-1 16.04-.07 16.36-.05c-.07.79-.62 1.95-1.41 2.93-.71.86-1.74 1.59-2.76 1.51-.13-.78.34-1.96.99-2.77z"/>
          </svg>
          <div class="store-text">
            <span class="store-sub">זמינה ב־</span>
            <span class="store-name">App Store</span>
          </div>
        </a>
        <a href="https://play.google.com/store/apps/details?id=app.maktuba" class="store-badge" aria-label="הורדה ב-Google Play">
          <svg class="store-icon" viewBox="0 0 24 24" width="26" height="26" aria-hidden="true">
            <path d="M3.6 1.7c-.3.3-.5.8-.5 1.4v18c0 .6.2 1.1.5 1.4l.1.1L13.8 12.1v-.2L3.7 1.7l-.1.1z" fill="currentColor" opacity="0.85"/>
            <path d="M17.2 15.5l-3.4-3.4v-.2l3.4-3.4.1.1 4 2.3c1.2.7 1.2 1.8 0 2.4l-4 2.2z" fill="currentColor"/>
            <path d="M17.3 15.4L13.8 12 3.6 22.3c.4.4 1.1.5 1.8.1l11.9-7z" fill="currentColor" opacity="0.7"/>
            <path d="M17.3 8.7l-11.9-7c-.7-.4-1.4-.4-1.8.1L13.8 12l3.5-3.3z" fill="currentColor" opacity="0.55"/>
          </svg>
          <div class="store-text">
            <span class="store-sub">זמינה ב־</span>
            <span class="store-name">Google Play</span>
          </div>
        </a>
      </div>

      <p class="hero-micro">50 מפתחות מתנה · קריאה ראשונה אצלי · ללא כרטיס אשראי</p>
    </div>

    <div class="hero-phone">
      <div class="phone-frame">
        <img src={appHome} alt="מכתובה — מסך הבית" width="280" height="560" loading="eager" />
      </div>
      <div class="phone-halo" aria-hidden="true"></div>
    </div>
  </div>

  <div class="hero-fade" aria-hidden="true"></div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: clamp(6rem, 10vw, 8rem) clamp(1.5rem, 5vw, 4rem) 5rem;
  }
  .hero-bg { position: absolute; inset: 0; }
  .hero-bg img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center 20%;
    transform: scale(1.08);
    filter: brightness(0.4) contrast(1.15) saturate(0.8);
    will-change: transform;
  }
  .hero-overlay {
    position: absolute; inset: 0;
    background:
      linear-gradient(to top, var(--ink) 0%, transparent 55%),
      linear-gradient(to right, var(--ink) 0%, rgba(10,6,18,0.55) 50%, transparent 100%),
      radial-gradient(ellipse at 30% 80%, rgba(212,165,116,0.06), transparent 60%);
  }
  .hero-fade {
    position: absolute; bottom: 0; left: 0; right: 0;
    height: 8rem;
    background: linear-gradient(to bottom, transparent, var(--ink));
    pointer-events: none;
  }
  .hero-inner {
    position: relative; z-index: 2;
    max-width: 1200px; margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
    width: 100%;
  }
  .hero-text { max-width: 580px; }
  .hero-mark {
    display: block;
    filter: drop-shadow(0 0 30px rgba(212,165,116,0.35));
    margin-bottom: 1.5rem;
    border-radius: 16px;
  }
  .hero-title {
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 900;
    font-size: clamp(4rem, 12vw, 7rem);
    line-height: 0.85;
    color: var(--gold);
    text-shadow: 0 0 60px rgba(212,165,116,0.3), 0 0 120px rgba(212,165,116,0.1);
    margin-bottom: 0.8rem;
  }
  .hero-tagline {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: clamp(1.4rem, 3.5vw, 2.2rem);
    color: var(--gold-light);
    letter-spacing: 0.03em;
    margin-bottom: 1.5rem;
    opacity: 0.92;
  }
  .hero-lead {
    font-family: 'Frank Ruhl Libre', serif;
    font-size: 1.05rem;
    color: rgba(235,227,211,0.78);
    max-width: 480px;
    margin-bottom: 2rem;
    line-height: 1.8;
  }

  /* KPI strip */
  .hero-kpi {
    display: flex; align-items: center;
    gap: clamp(0.8rem, 2vw, 1.5rem);
    padding: 1.2rem 0;
    margin-bottom: 1.6rem;
    border-top: 1px solid rgba(212,165,116,0.15);
    border-bottom: 1px solid rgba(212,165,116,0.15);
  }
  .kpi {
    display: flex; flex-direction: column;
    align-items: flex-start;
    line-height: 1.1;
  }
  .kpi-num {
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 900;
    font-size: clamp(1.6rem, 3.2vw, 2.1rem);
    color: var(--gold-hi);
    letter-spacing: -0.01em;
  }
  .kpi-label {
    font-family: 'Heebo', sans-serif;
    font-size: 0.7rem;
    color: rgba(235,227,211,0.55);
    margin-top: 4px;
    letter-spacing: 0.05em;
  }
  .kpi-stars {
    font-size: 0.65rem;
    color: var(--gold);
    letter-spacing: 0.15em;
    margin-top: 2px;
  }
  .kpi-sep {
    width: 1px; height: 32px;
    background: rgba(212,165,116,0.18);
  }

  /* Store badges */
  .hero-badges {
    display: flex; flex-wrap: wrap; gap: 0.7rem;
    margin-bottom: 1.4rem;
  }
  .store-badge {
    display: inline-flex; align-items: center; gap: 12px;
    padding: 11px 22px 11px 18px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 14px;
    color: var(--parchment);
    text-decoration: none;
    transition: background 280ms cubic-bezier(0.22,1,0.36,1),
                border-color 280ms cubic-bezier(0.22,1,0.36,1),
                transform 240ms cubic-bezier(0.22,1,0.36,1);
  }
  .store-badge:hover {
    background: rgba(255,255,255,0.1);
    border-color: rgba(212,165,116,0.35);
    transform: translateY(-2px);
  }
  .store-icon { flex-shrink: 0; opacity: 0.95; }
  .store-text { display: flex; flex-direction: column; line-height: 1.1; }
  .store-sub {
    font-family: 'Heebo', sans-serif;
    font-size: 0.62rem;
    font-weight: 400;
    color: rgba(235,227,211,0.55);
    letter-spacing: 0.03em;
    margin-bottom: 2px;
  }
  .store-name {
    font-family: 'Heebo', sans-serif;
    font-size: 1rem;
    font-weight: 500;
  }

  .hero-micro {
    font-family: 'Heebo', sans-serif;
    font-size: 0.74rem;
    color: var(--muted);
    letter-spacing: 0.08em;
  }

  /* Phone */
  .hero-phone {
    position: relative;
    display: flex; align-items: center; justify-content: center;
  }
  .phone-frame {
    position: relative;
    width: 280px;
    background: #111;
    border-radius: 36px;
    padding: 12px;
    box-shadow:
      0 30px 80px rgba(0,0,0,0.6),
      0 0 0 1px rgba(255,255,255,0.06),
      0 0 60px rgba(212,165,116,0.08);
    z-index: 1;
  }
  .phone-frame::before {
    content: '';
    position: absolute;
    top: 10px; left: 50%; transform: translateX(-50%);
    width: 80px; height: 6px;
    background: #222;
    border-radius: 999px;
    z-index: 2;
  }
  .phone-frame img {
    width: 100%; height: auto;
    border-radius: 26px;
    display: block;
  }
  .phone-halo {
    position: absolute;
    inset: -40px;
    background: radial-gradient(ellipse at center, rgba(212,165,116,0.12), transparent 60%);
    z-index: 0;
    pointer-events: none;
  }

  @media (max-width: 860px) {
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: right;
    }
    .hero-text { max-width: 100%; }
    .hero-kpi { justify-content: flex-start; flex-wrap: wrap; }
    .hero-badges { justify-content: flex-start; }
    .hero-phone { margin-top: 2rem; order: 2; }
    .phone-frame { width: 220px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .store-badge { transition: none; }
  }
</style>
