---
import { getCollection } from "astro:content";
import Base from "@/layouts/Base.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Quiz from "@/components/Quiz.astro";

export const prerender = true;

export async function getStaticPaths() {
  const lessons = await getCollection("lessons");
  return lessons.map((l) => ({
    params: { course: l.data.courseId, slug: l.data.slug },
    props: { lesson: l },
  }));
}

const { lesson } = Astro.props;
const d = lesson.data;
const courseIndexUrl = `/academy/${d.courseId}`;
const canonical = `https://maktuba.app/academy/${d.courseId}/${d.slug}`;

const articleLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: d.seo.title,
  description: d.seo.description,
  author: { "@type": "Organization", name: "Maktuba Academy", url: "https://maktuba.app" },
  publisher: {
    "@type": "Organization",
    name: "Maktuba",
    logo: { "@type": "ImageObject", url: "https://maktuba.app/logo.png" },
  },
  datePublished: d.datePublished,
  dateModified: d.dateModified,
  mainEntityOfPage: canonical,
  inLanguage: "he",
  isPartOf: {
    "@type": "Course",
    name: d.module,
    provider: { "@type": "Organization", name: "Maktuba Academy" },
  },
};

const quizLd = {
  "@context": "https://schema.org",
  "@type": "Quiz",
  name: `בחן את עצמך — ${d.title}`,
  about: d.title,
  hasPart: d.sections.quiz.questions.map((q) => ({
    "@type": "Question",
    text: q.question,
    acceptedAnswer: { "@type": "Answer", text: q.options[q.correct] },
  })),
};

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: d.faq.map((f) => ({
    "@type": "Question",
    name: f.question,
    acceptedAnswer: { "@type": "Answer", text: f.answer },
  })),
};

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "אקדמיה", item: "https://maktuba.app/academy" },
    { "@type": "ListItem", position: 2, name: d.module, item: `https://maktuba.app${courseIndexUrl}` },
    { "@type": "ListItem", position: 3, name: d.title },
  ],
};
---

<Base
  title={d.seo.title}
  description={d.seo.description}
  keywords={d.seo.keywords}
  canonical={canonical}
  ogImage={d.seo.ogImage ?? "/og-default.png"}
  ogType="article"
  jsonLd={[articleLd, quizLd, faqLd, breadcrumbLd]}
>
  <Header lang="he" />

  <div class="max-w-3xl mx-auto px-6 py-6">
    <nav aria-label="breadcrumb" class="text-xs text-muted mb-6">
      <ol class="flex flex-wrap items-center gap-2">
        <li><a href="/academy" class="hover:text-gold">אקדמיה</a></li>
        <li>›</li>
        <li><a href={courseIndexUrl} class="hover:text-gold">{d.module}</a></li>
        <li>›</li>
        <li class="text-body-text/70">{d.title}</li>
      </ol>
    </nav>
  </div>

  <main class="max-w-3xl mx-auto px-6 pb-16">
    <article class="prose prose-invert prose-maktuba max-w-none">
      <header class="mb-10 not-prose">
        <span class="inline-block text-[11px] tracking-[0.2em] uppercase text-gold/70 border border-gold/30 px-2 py-0.5 rounded-sm">
          {d.module}
        </span>
        <h1 class="font-display text-3xl sm:text-4xl text-gold mt-4 mb-3 leading-tight">
          {d.title}
        </h1>
        <div class="flex flex-wrap items-center gap-4 text-xs text-muted">
          <time>{d.datePublished}</time>
          <span>⏱ {d.estimatedMinutes} דק׳ קריאה</span>
          <span>שיעור {d.lessonNumber}</span>
        </div>
      </header>

      <section id="opening" class="lesson-opening" set:html={d.sections.opening} />
      <section id="theory-a" set:html={d.sections.theoryA} />

      <aside class="practice-box not-prose" id="practice-1">
        <h3 class="font-display text-lg text-gold mb-2">🔮 עצור/עצרי ותרגל/תרגלי</h3>
        <p class="text-body-text/90">{d.sections.practice1.instruction}</p>
      </aside>

      <section id="theory-b" set:html={d.sections.theoryB} />

      <aside class="practice-box not-prose" id="practice-2">
        <h3 class="font-display text-lg text-gold mb-2">🔮 תרגול מתקדם</h3>
        <p class="text-body-text/90">{d.sections.practice2.instruction}</p>
      </aside>

      <aside class="deep-dive-box not-prose" id="deep-dive" set:html={d.sections.deepDive} />

      <section id="quiz" class="not-prose">
        <h2 class="font-display text-2xl text-gold mt-10 mb-4">📝 בחן את עצמך</h2>
        <Quiz quiz={d.sections.quiz} storageKey={`maktuba_academy_${d.courseId}_${d.lessonNumber}`} />
      </section>

      <section id="summary" class="not-prose mt-10">
        <h2 class="font-display text-2xl text-gold mb-3">סיכום</h2>
        <p class="text-body-text/90">{d.sections.closing.summary}</p>
        <blockquote class="wisdom mt-6">
          <p>💡 {d.sections.closing.wisdom}</p>
        </blockquote>
        <p class="mt-6 text-sm text-body-text/70">
          <strong class="text-gold-light">בשיעור הבא:</strong> {d.sections.closing.nextPreview}
        </p>
      </section>

      <section id="faq" class="not-prose mt-12">
        <h2 class="font-display text-2xl text-gold mb-4">שאלות נפוצות</h2>
        <div class="space-y-4">
          {d.faq.map((f) => (
            <details class="border border-border bg-surface/60 p-4 rounded-sm">
              <summary class="cursor-pointer font-medium text-gold-light">{f.question}</summary>
              <p class="mt-3 text-sm text-body-text/85">{f.answer}</p>
            </details>
          ))}
        </div>
      </section>

      {d.crossReferences.length > 0 && (
        <section class="not-prose mt-12">
          <h2 class="font-display text-xl text-gold mb-4">שיעורים קשורים</h2>
          <div class="grid sm:grid-cols-3 gap-3">
            {d.crossReferences.map((ref) => (
              <a href={`/academy/${ref.course}/${ref.lesson}`} class="text-sm border border-border p-3 rounded-sm hover:border-gold/40 hover:bg-surface-2 transition-colors">
                {ref.label}
              </a>
            ))}
          </div>
        </section>
      )}
    </article>

    <aside class="mt-16 border border-gold/30 bg-surface-2/80 p-8 rounded-sm text-center not-prose">
      <h2 class="font-display text-2xl text-gold mb-2">🔮 רוצה לתרגל עם מכתובה?</h2>
      <p class="text-body-text/80 mb-4">
        הורד/הורידי את האפליקציה ותקבל/י קריאה מאגית ראשונה חינם, בנוסף ל-10 מפתחות מתנה.
      </p>
      <a href="/app" class="btn-gold">📱 קבלי קריאה עם מכתובה</a>
    </aside>
  </main>

  <Footer lang="he" />
</Base>
