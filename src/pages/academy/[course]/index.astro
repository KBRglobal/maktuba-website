---
import { getCollection } from "astro:content";
import Base from "@/layouts/Base.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import config from "@data/academy-config.json";

export const prerender = true;

export async function getStaticPaths() {
  return config.courses.map((c) => ({ params: { course: c.id }, props: { course: c } }));
}

const { course } = Astro.props;
const allLessons = await getCollection("lessons", (l) => l.data.courseId === course.id);
const lessonsByModule = new Map<string, typeof allLessons>();
for (const l of allLessons) {
  const arr = lessonsByModule.get(l.data.module) ?? [];
  arr.push(l);
  lessonsByModule.set(l.data.module, arr);
}
for (const arr of lessonsByModule.values()) arr.sort((a, b) => a.data.lessonNumber - b.data.lessonNumber);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Course",
  name: course.titleHe,
  description: `קורס חינמי ב${course.titleHe} — ${course.lessonCount} שיעורים מלאים.`,
  provider: { "@type": "Organization", name: "Maktuba Academy", url: "https://maktuba.app" },
  isAccessibleForFree: true,
  numberOfLessons: course.lessonCount,
  inLanguage: ["he", "en", "ar"],
};
---

<Base
  title={`${course.titleHe} — אקדמיית מכתובה | ${course.lessonCount} שיעורים חינם`}
  description={`קורס חינמי ב${course.titleHe}: ${course.lessonCount} שיעורים מלאים, בחינה בסוף כל שיעור, קישורים לקורסים קשורים. בעברית, אנגלית וערבית.`}
  keywords={[course.titleHe, `קורס ${course.titleHe}`, "אקדמיית מכתובה", `${course.titleEn} course`, `${course.titleEn} free`]}
  jsonLd={jsonLd}
>
  <Header lang="he" />
  <main class="max-w-4xl mx-auto px-6 py-16">
    <nav aria-label="breadcrumb" class="text-xs text-muted mb-6">
      <ol class="flex flex-wrap items-center gap-2">
        <li><a href="/academy" class="hover:text-gold">אקדמיה</a></li>
        <li>›</li>
        <li class="text-body-text/70">{course.titleHe}</li>
      </ol>
    </nav>

    <header class="text-center mb-12 space-y-3">
      <div class="text-5xl">{course.icon}</div>
      <h1 class="font-display text-4xl text-gold tracking-[0.08em]">{course.titleHe}</h1>
      <p class="text-body-text/70">
        {course.lessonCount} שיעורים · חינם · עברית/אנגלית/ערבית
      </p>
    </header>

    {allLessons.length === 0 ? (
      <p class="text-center text-muted py-12 border border-border rounded-sm">
        השיעורים של הקורס הזה עדיין נכתבים. חזור/חזרי בקרוב 📜
      </p>
    ) : (
      <div class="space-y-10">
        {[...lessonsByModule.entries()].map(([module, lessons]) => (
          <section>
            <h2 class="font-display text-xl text-gold-light tracking-wider mb-4">{module}</h2>
            <ol class="space-y-2">
              {lessons.map((l) => (
                <li>
                  <a
                    href={`/academy/${course.id}/${l.data.slug}`}
                    class="flex items-center justify-between px-4 py-3 border border-border bg-surface/50 hover:border-gold/40 hover:bg-surface-2/80 transition-colors rounded-sm"
                  >
                    <span class="text-body-text/90">
                      <span class="text-gold/70 me-2">{String(l.data.lessonNumber).padStart(2, "0")}.</span>
                      {l.data.title}
                    </span>
                    <span class="text-xs text-muted">{l.data.estimatedMinutes} דק׳</span>
                  </a>
                </li>
              ))}
            </ol>
          </section>
        ))}
      </div>
    )}
  </main>
  <Footer lang="he" />
</Base>
