---
import Base from "@/layouts/Base.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import config from "@data/academy-config.json";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "EducationalOrganization",
  "name": "Maktuba Academy",
  "url": "https://maktuba.app/academy",
  "description": "אקדמיה חינמית למיסטיקה וחוכמה עתיקה — 194 שיעורים, 10 קורסים.",
};

const courses = config.courses;
---
<Base
  title="אקדמיית מכתובה — 194 שיעורים חינם על חוכמה עתיקה"
  description="קורסים חינמיים על טארוט, קריאה בקפה, כף יד, אסטרולוגיה, קבלה, נומרולוגיה ועוד. בעברית, אנגלית וערבית."
  keywords={["אקדמיית מכתובה","קורס טארוט חינם","קורס אסטרולוגיה","קורס קבלה","נומרולוגיה"]}
  jsonLd={jsonLd}
>
  <Header lang="he" />
  <main class="max-w-5xl mx-auto px-6 py-20">
    <header class="text-center mb-16 space-y-4">
      <h1 class="font-display text-4xl sm:text-5xl text-gold tracking-[0.08em]">אקדמיית מכתובה</h1>
      <p class="text-body-text/70 max-w-2xl mx-auto">
        10 קורסים. 194 שיעורים. חינם לגמרי. כל מה שרצית לדעת על החוכמה המיסטית —
        כתוב, מאורגן, ומסומן בסמל הנכון.
      </p>
    </header>

    <section class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {courses.map((c) => (
        <a href={`/academy/${c.id}`} class="group border border-border bg-surface/60 hover:border-gold/40 hover:bg-surface-2/80 transition-colors p-6 rounded-sm block">
          <div class="text-3xl mb-3">{c.icon}</div>
          <h2 class="font-display text-lg text-gold tracking-wider mb-1">{c.titleHe}</h2>
          <p class="text-xs text-muted group-hover:text-body-text/70 transition-colors">
            {c.lessonCount} שיעורים
          </p>
        </a>
      ))}
    </section>
  </main>
  <Footer lang="he" />
</Base>
