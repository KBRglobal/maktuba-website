---
import Base from "@/layouts/Base.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Icon from "@/components/Icon.astro";
import config from "@data/academy-config.json";
import { COURSE_COVER, CHARACTER } from "@/lib/images";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "EducationalOrganization",
  name: "Maktuba Academy",
  url: "https://maktuba.app/academy",
  description: "אקדמיה חינמית למיסטיקה וחוכמה עתיקה — 194 שיעורים, 10 קורסים, שלוש שפות.",
};

const courses = config.courses;
const featured = courses[0]; // tarot

/** Icon mapping per course — explicit, intentional */
const COURSE_ICON: Record<string, string> = {
  tarot: "tarot", coffee: "coffee", palm: "palm", astrology: "moon",
  numerology: "number", kabbalah: "letter-beth", dreams: "eye",
  iching: "hexagram", crystals: "crystal", psalms: "book",
};
---
<Base
  title="אקדמיית מכתובה — 194 שיעורים חינם על חוכמה עתיקה"
  description="קורסים חינמיים על טארוט, קריאה בקפה, כף יד, אסטרולוגיה, קבלה, נומרולוגיה, חלומות ועוד. עשרה קורסים, 194 שיעורים מלאים, בעברית, אנגלית וערבית. בלי רישום, בלי חיוב, בלי תנאי."
  keywords={["אקדמיית מכתובה","קורס טארוט חינם","קורס אסטרולוגיה","קורס קבלה","נומרולוגיה","קריאה בקפה לימוד","תהילים לימוד"]}
  jsonLd={jsonLd}
>
  <Header lang="he" />

  <!-- Hero — editorial magazine opening -->
  <section class="relative overflow-hidden border-b border-border/60">
    <div class="absolute inset-0 pointer-events-none opacity-30">
      <img src={CHARACTER.readingBook} alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(10,6,18,0.5), var(--ink-deep) 70%);"></div>
    </div>
    <div class="relative max-w-6xl mx-auto px-6 py-24 md:py-32">
      <p class="eyebrow">The Manuscript — Volume I</p>
      <h1 class="text-[56px] md:text-[112px] leading-[0.9] mt-5" style="letter-spacing:-0.01em;">
        אקדמיית<br/>מכתובה
      </h1>
      <p class="max-w-xl text-[18px] leading-[1.6] text-parchment-2/85 mt-8">
        עשרה קורסים. 194 שיעורים. שלוש שפות. הכל כתוב ביד אחת, בקול אחד — של מכתובה. בלי רישום, בלי חיוב, בלי מודעות.
      </p>
      <div class="flex flex-wrap items-center gap-6 mt-10 text-[13px] tracking-[0.2em] uppercase text-muted">
        <span class="flex items-center gap-2"><Icon name="book" size={18} stroke="#d4a574" /> 194 שיעורים</span>
        <span class="flex items-center gap-2"><Icon name="six-star" size={18} stroke="#d4a574" /> 10 קורסים</span>
        <span class="flex items-center gap-2"><Icon name="infinity" size={18} stroke="#d4a574" /> חינם תמיד</span>
      </div>
    </div>
  </section>

  <!-- Featured course — big editorial plate -->
  <section class="relative z-10 py-20 border-b border-border/60">
    <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-5 gap-12 items-center">
      <div class="md:col-span-2 plate">
        <img src={COURSE_COVER[featured.id]} alt={featured.titleHe} loading="lazy" />
      </div>
      <div class="md:col-span-3 space-y-5">
        <p class="eyebrow">הכרך המלא · הכי מבוקש</p>
        <h2 class="text-[48px] md:text-[72px] leading-[0.95]">{featured.titleHe}</h2>
        <p class="text-parchment-2/85 text-[17px] leading-[1.6] max-w-lg">
          שלושים שיעורים על Major Arcana, Minor Arcana, קורט קארדים, ופריסות.
          משלב קבלה, אסטרולוגיה, ונומרולוגיה — כי קלף לעולם לא לבד.
        </p>
        <div class="flex gap-4 pt-2">
          <a href={`/academy/${featured.id}`} class="btn-gold">התחילי את הקורס</a>
          <a href="#all-courses" class="btn-ghost">כל הקורסים</a>
        </div>
      </div>
    </div>
  </section>

  <!-- All courses — rich tiles with cover images + icons -->
  <section id="all-courses" class="relative z-10 py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex items-baseline justify-between mb-12 flex-wrap gap-4">
        <h2 class="text-[40px] md:text-[48px]">עשרת הקורסים</h2>
        <p class="text-muted text-[13px] tracking-[0.2em] uppercase">ממוין לפי עומק</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {courses.map((c) => (
          <a href={`/academy/${c.id}`} class="group block">
            <article class="plate aspect-[5/3] overflow-hidden relative">
              <img
                src={COURSE_COVER[c.id] ?? CHARACTER.silhouette}
                alt={c.titleHe}
                loading="lazy"
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.05]"
              />
              <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(10,6,18,0.85) 0%, rgba(10,6,18,0.2) 60%);"></div>
              <div class="absolute top-3 inset-inline-end-3 w-10 h-10 flex items-center justify-center bg-[var(--ink-deep)]/80 border border-gold/30 backdrop-blur-sm">
                <Icon name={COURSE_ICON[c.id] as any} size={20} stroke="#d4a574" />
              </div>
              <div class="absolute bottom-4 inset-inline-start-4 inset-inline-end-4">
                <h3 class="text-[22px] leading-tight text-gold-light">{c.titleHe}</h3>
                <p class="text-[12px] tracking-[0.2em] uppercase text-parchment-2/70 mt-1">
                  {c.lessonCount} שיעורים · {Math.round(c.lessonCount * 0.25)} שעות
                </p>
              </div>
            </article>
          </a>
        ))}
      </div>

      <div class="rule-star mt-20"></div>

      <!-- Meta footer for academy -->
      <div class="text-center max-w-xl mx-auto space-y-4">
        <blockquote class="wisdom">
          ״הידע לא נבנה במהירות. שבי. כל שיעור פותח דלת אחת. כל דלת — חדר.״
        </blockquote>
        <p class="text-[13px] text-muted">כל השיעורים מתוחזקים על ידי מכתובה + AI · מעודכנים חודשית</p>
      </div>
    </div>
  </section>

  <Footer lang="he" />
</Base>
