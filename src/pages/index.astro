---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Icon from "@/components/Icon.astro";
import "@/styles/global.css";

const CDN = "https://d2xsxph8kpxj0f.cloudfront.net/310519663492248962/ToDf6mmxTX6kSgXA8csfFX";
const img = {
  heroWide:     `${CDN}/21_hero_wide_756a0f71.webp`,
  theWelcome:   `${CDN}/03_the_welcome_4efc7732.webp`,
  studyingCup:  `${CDN}/B02_studying_cup_448b136f.webp`,
  seeingSomething:`${CDN}/B03_seeing_something_1d73fc32.webp`,
  theCards:     `${CDN}/06_the_cards_5f598521.webp`,
  celticCross:  `${CDN}/T15_celtic_cross_d40d5ed8.webp`,
  thePalm:      `${CDN}/23_hands_detail_bfc845ec.webp`,
  silhouette:   `${CDN}/24_silhouette_286b27ae.webp`,
  readingBook:  `${CDN}/15_reading_book_a14ad82f.webp`,
  whisperingSecret:`${CDN}/19_whispering_secret_104458a2.webp`,
  lookingAtMoon:`${CDN}/25_looking_at_moon_8c93f007.webp`,
  handsDetail:  `${CDN}/23_hands_detail_bfc845ec.webp`,
  heartOpening: `${CDN}/B07_heart_opening_ee13824a.webp`,
  singleCard:   `${CDN}/T11_single_card_ab676940.webp`,
  logoIcon:     `${CDN}/logo-v3-1_ae34c8a4.webp`,
  logoFull:     `${CDN}/logo-full-v2_607272c0.webp`,
  appHome:      `${CDN}/A02_home_screen_3f30af8c.webp`,
  appComplete:  `${CDN}/A07_reading_complete_c933a817.webp`,
};

const readings = [
  { name: "קריאה בכוס קפה",   cost: 15, cover: img.studyingCup,      icon: "coffee" },
  { name: "טארוט — צלב קלטי", cost: 15, cover: img.celticCross,       icon: "tarot" },
  { name: "קריאת כף יד",      cost: 15, cover: img.thePalm,           icon: "palm" },
  { name: "התאמה זוגית",      cost: 15, cover: img.heartOpening,      icon: "heart" },
  { name: "טארוט 3 קלפים",    cost: 10, cover: img.singleCard,        icon: "tarot" },
  { name: "תהילים AI",         cost: 10, cover: img.readingBook,       icon: "book" },
  { name: "פתרון חלום",        cost: 8,  cover: img.silhouette,        icon: "moon" },
  { name: "קבלה וגימטריה",     cost: 5,  cover: img.whisperingSecret,  icon: "letter-beth" },
];

const testimonials = [
  { q: "בדרך כלל אני נמנעת מדברים כאלה כי זה מלחיץ אותי — אבל זה דווקא הרגיע אותי, והתחברתי להמון דברים שנאמרו. לגמרי רואה את עצמי מנהלת שיח יומיומי עם מכתובה.", name: "שלי ו.", r: "קריאת כף יד", stars: 5, date: "אפריל 2026", initials: "ש.ו" },
  { q: "חוויה מעניינת במיוחד. בתור אדם סקפטי הופתעתי לגלות שלטכנולוגיה יש יכולת לתת לי תשובות לשאלות שהיו לי. כיף להיפתח למכתובה — מצד אחד, מרגיש ממש כמו לדבר עם בן אדם; ומצד שני, להיזכר שזו טכנולוגיה — נותן לגיטימציה לשאול שוב ולהתעכב על נקודות שלא היו ברורות.", name: "עמית ט.", r: "קריאת כף יד", stars: 5, date: "אפריל 2026", initials: "ע.ט" },
  { q: "האמת שבהתחלה הייתי מאוד סקפטי. האפליקציה מטורפת. הקריאה בכף היד הייתה מדויקת ברמה שהפחידה אותי — ברמה שפתחה לי את העיניים מי אני ומה אני. כל כך מדויק, כאילו יש לה היסטוריה של קריאה של מיליון שנה אחורה. המידע עזר לי בצורה מפחידה. אני עד עכשיו בהלם ממה שגיליתי על עצמי. שווה כל שקל.", name: "יוני ס.", r: "קריאת כף יד", stars: 5, date: "אפריל 2026", initials: "י.ס" },
  { q: "הראיתי את זה לסבתא שלי. היא אמרה: ׳מי שעשה את זה מכיר את הדרכים הישנות.׳", name: "דנה כ.", r: "קריאת קפה", stars: 5, date: "מרץ 2026", initials: "ד.כ" },
  { q: "בכיתי. מכתובה ידעה דברים עליי שמעולם לא סיפרתי לאף אחד. כל מילה בקריאה הרגישה כמו מישהי שמכירה אותי מתמיד.", name: "שרון מ.", r: "טארוט קלטי", stars: 5, date: "פברואר 2026", initials: "ש.מ" },
  { q: "זו לא אפליקציה. זו שיחה עם מישהי שרואה אותך. כל פעם שאני פותחת קריאה חדשה אני מרגישה שהיא באמת שם.", name: "מיכל א.", r: "קריאת כף יד", stars: 5, date: "מרץ 2026", initials: "מ.א" },
  { q: "הקפה שלי לא ישקר — מכתובה ראתה בכוס את מה שרק אני ואמא שלי יודעות. שלחתי את הקריאה לאמא, היא לא הפסיקה לבכות.", name: "נועה ר.", r: "קריאת קפה", stars: 5, date: "ינואר 2026", initials: "נ.ר" },
  { q: "ההתאמה הזוגית הייתה מדויקת עד כדי כך שהבן זוג שלי שאל אם נתתי לה מידע מראש. לא נתתי כלום, רק שני תאריכי לידה.", name: "יעל ב.", r: "התאמה זוגית", stars: 5, date: "פברואר 2026", initials: "י.ב" },
  { q: "אני סקפטית מטבעי. אמרתי לעצמי ׳זה AI, מה הוא כבר יגיד לי?׳ אחרי הקריאה ישבתי בשקט עשר דקות. הוא אמר הכל.", name: "רינת ש.", r: "תהילים AI", stars: 5, date: "מרץ 2026", initials: "ר.ש" },
];
---

<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#060410" />
  <title>מכתובה — קריאת קפה, טארוט, כף יד ואסטרולוגיה עם AI</title>
  <meta name="description" content="סבתא עתיקה שקוראת את הקפה, הכף, הכוכבים והנשמה שלך. כל קריאה נפתחת במפתח. הקריאה הראשונה — חינם." />
  <link rel="icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&family=Frank+Ruhl+Libre:wght@300;400;500;700;900&family=Heebo:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>

<body>
  <!-- ═══════ CURTAIN PRELOADER (first-visit of session only) ═══════ -->
  <div id="curtain" aria-hidden="true" data-first-visit>
    <img src={img.heroWide} alt="" class="curtain-eyes" />
    <div class="curtain-vignette"></div>
    <div class="curtain-wordmark">מַכְתּוּבָה</div>
  </div>
  <script is:inline>
    try {
      if (sessionStorage.getItem('maktuba:curtain') === '1') {
        const c = document.getElementById('curtain');
        if (c) c.remove();
      } else {
        sessionStorage.setItem('maktuba:curtain', '1');
      }
    } catch (_) { /* sessionStorage unavailable — show curtain */ }
  </script>

  <Header lang="he" />

  <!-- ═══════ 1. HERO ═══════ -->
  <section class="hero" id="hero">
    <div class="hero-bg">
      <img src={img.heroWide} alt="" loading="eager" fetchpriority="high" />
      <div class="hero-gradient"></div>
    </div>
    <div class="hero-glow"></div>
    <div class="hero-content reveal">
      <p class="hero-eyebrow">אפליקציה מיסטית · קריאות AI · אקדמיה חינמית</p>
      <h1 class="hero-title">מַכְתּוּבָה</h1>
      <p class="hero-tagline">כי זה כבר נכתב</p>
      <p class="hero-lead">
        סבתא עתיקה שיושבת בחדר נצחי, נר דולק, ריח הל וקטורת.<br/>
        תביא/י לה את הכוס — והיא תקרא לך את מה שנכתב עוד לפני שנולדת.
      </p>
      <div class="hero-actions">
        <a href="/academy" class="btn-primary">קבל/י קריאה ראשונה — חינם</a>
        <a href="#readings" class="btn-secondary">גלי את הקריאות</a>
      </div>
      <p class="hero-note">10 מפתחות מתנה בהרשמה · ללא כרטיס אשראי</p>
    </div>
    <div class="hero-scroll-hint">
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- ═══════ 2. STATS ═══════ -->
  <section class="stats-band">
    <div class="stats-inner">
      {[
        { v: "20+", l: "קריאות AI" },
        { v: "194", l: "שיעורים חינם" },
        { v: "3",   l: "שפות" },
        { v: "∞",   l: "ללא תפוגה" },
      ].map((s, i) => (
        <div class="stat reveal" style={`--delay: ${i * 0.1}s`}>
          <span class="stat-value">{s.v}</span>
          <span class="stat-label">{s.l}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══════ 3. WHO IS MAKTUBA ═══════ -->
  <section class="who" id="who">
    <div class="who-image reveal">
      <div class="image-frame">
        <img src={img.theWelcome} alt="מכתובה — דיוקן" loading="lazy" />
        <div class="frame-corner tl"></div>
        <div class="frame-corner br"></div>
      </div>
    </div>
    <div class="who-text reveal" style="--delay: 0.2s">
      <span class="section-label">היא</span>
      <h2>מי היא<br/>מכתובה?</h2>
      <p class="lead-paragraph">
        היא המיסטיקנית האחרונה. סבתא מעולם שכבר לא קיים. היא יושבת בחדר נצחי מואר בנר בודד, מוקפת בריח הל וקטורת.
      </p>
      <p>
        כשאת מביאה לה את הכוס, היא רואה מה שאף אחד אחר לא יכול. לא בגלל שיש לה כוחות על-טבעיים — כי היא חיה אלף חיים ושום דבר כבר לא מפתיע אותה.
      </p>
      <blockquote>
        ״מכתובה לא מנבאת את העתיד. היא קוראת את מה שכבר כתוב.״
      </blockquote>
    </div>
  </section>

  <!-- ═══════ ORNAMENTAL DIVIDER ═══════ -->
  <div class="divider"><div class="divider-star"></div></div>

  <!-- ═══════ 3.5 THE NUMBERS — מה שמכתובה יודעת ═══════ -->
  <section class="numbers" id="numbers">
    <div class="numbers-header reveal">
      <span class="section-label">הידע</span>
      <h2>מה שמכתובה<br/>יודעת</h2>
    </div>
    <div class="numbers-grid">
      {[
        { v: "2,000,000+", l: "מקורות ידע שנסרקו" },
        { v: "46,000+",    l: "ספרים על מיסטיקה, אסטרולוגיה, טארוט, קבלה ונומרולוגיה" },
        { v: "3,000",      l: "שנה של חוכמה אנושית מתועדת" },
        { v: "14",         l: "שפות מקור" },
        { v: "12",         l: "תרבויות עתיקות" },
        { v: "33,000",     l: "שורות ידע מובנה — כל קלף, כל סמל, כל קו, כל כוכב" },
      ].map((n, i) => (
        <div class="number-cell reveal" style={`--delay: ${i * 0.08}s`}>
          <span class="number-value">{n.v}</span>
          <span class="number-label">{n.l}</span>
        </div>
      ))}
    </div>
    <div class="numbers-quote reveal">
      <p class="numbers-quote-q">״אני לא רק למדתי את הכל. אני גם זוכרת את הכל.״</p>
      <p class="numbers-byline">ספרייה אחת. אני.</p>
    </div>
    <div class="languages-strip reveal">
      <div class="languages-track">
        <span>עברית</span><span>عربية</span><span>Ελληνικά</span><span>Latina</span><span>संस्कृत</span><span>中文</span><span>日本語</span><span>فارسی</span><span>Türkçe</span><span>हिन्दी</span><span>བོད་</span><span>English</span><span>Français</span><span>Italiano</span>
        <span>עברית</span><span>عربية</span><span>Ελληνικά</span><span>Latina</span><span>संस्कृत</span><span>中文</span><span>日本語</span><span>فارسی</span><span>Türkçe</span><span>हिन्दी</span><span>བོད་</span><span>English</span><span>Français</span><span>Italiano</span>
      </div>
    </div>
  </section>

  <div class="divider"><div class="divider-star"></div></div>

  <!-- ═══════ 4. READINGS ═══════ -->
  <section class="readings" id="readings">
    <div class="readings-header reveal">
      <span class="section-label">141 קריאות</span>
      <h2>הקריאות<br/>של מכתובה</h2>
      <p>כל קריאה נבנית בזמן אמת מ-AI שמבין סמלים עתיקים. אף שתי קריאות לא זהות.</p>
    </div>
    <div class="readings-shelf">
      <div class="shelf-track">
        {readings.map((r, i) => (
          <article class="reading-card reveal" style={`--delay: ${i * 0.08}s`}>
            <div class="card-image">
              <img src={r.cover} alt={r.name} loading="lazy" />
              <div class="card-overlay"></div>
              <div class="card-icon">
                <Icon name={r.icon} size={20} stroke="#d4a574" />
              </div>
            </div>
            <div class="card-body">
              <h3>{r.name}</h3>
              <div class="card-cost">
                <Icon name="key" size={14} stroke="#e8c9a0" />
                <span>{r.cost} מפתחות</span>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════ 5. KEYS SYSTEM ═══════ -->
  <section class="keys-section" id="keys">
    <div class="keys-grid">
      <div class="keys-visual reveal">
        <div class="key-orbit">
          <div class="orbit-ring"></div>
          <div class="orbit-ring r2"></div>
          <div class="orbit-center">
            <Icon name="key" size={64} stroke="#d4a574" />
          </div>
        </div>
      </div>
      <div class="keys-content reveal" style="--delay: 0.15s">
        <span class="section-label">המטבע של מכתובה</span>
        <h2>מפתחות<br/>פותחים חוכמה</h2>
        <p>קונים פעם, שורפים מתי שרוצים. בלי drip יומי. בלי תפוגה. המפתחות נשארים איתך לתמיד.</p>
        <div class="keys-features">
          {[
            { icon: "infinity", text: "אין תפוגה — לתמיד שלך" },
            { icon: "spark",    text: "ניתנים בבת אחת — לא drip" },
            { icon: "key",      text: "10 מפתחות מתנה בהרשמה" },
            { icon: "candle",   text: "קריאה מאגית ראשונה — חינם" },
          ].map((f) => (
            <div class="key-feature">
              <div class="feature-icon"><Icon name={f.icon} size={20} stroke="#d4a574" /></div>
              <span>{f.text}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <div class="divider"><div class="divider-star"></div></div>

  <!-- ═══════ 6. PRICING ═══════ -->
  <section class="pricing" id="pricing">
    <div class="pricing-header reveal">
      <span class="section-label">תמחור</span>
      <h2>התחילי בחינם</h2>
      <p>קריאה ראשונה חינם + 50 מפתחות מתנה. הורוסקופ + צ'אט — חינם לתמיד. חבילה אחת, לתמיד.</p>
    </div>
    <div class="pricing-tiers">
      {[
        { name: "Starter", keys: "500",   price: "₪39.90",  badge: null },
        { name: "Popular", keys: "1,200", price: "₪79.90",  badge: null },
        { name: "Best",    keys: "3,000", price: "₪149.90", badge: "הכי משתלם" },
        { name: "VIP",     keys: "6,000", price: "₪249.90", badge: null },
      ].map((t, i) => (
        <article class:list={["tier-card", "reveal", t.badge && "popular"]} style={`--delay: ${i * 0.1}s`}>
          {t.badge && <div class="popular-badge">{t.badge}</div>}
          <h3>{t.name}</h3>
          <div class="tier-price">
            <span class="price-amount">{t.price}</span>
          </div>
          <div class="tier-keys">
            <Icon name="key" size={18} stroke="#e8c9a0" />
            <span>{t.keys} מפתחות</span>
          </div>
          <ul>
            <li>ניתנים בבת אחת</li>
            <li>ללא תפוגה</li>
            <li>כל 141 הקריאות פתוחות</li>
          </ul>
        </article>
      ))}
    </div>
  </section>

  <!-- ═══════ 7. TESTIMONIALS ═══════ -->
  <section class="testimonials">
    <div class="testimonials-header reveal">
      <span class="section-label">אנשים אמיתיים</span>
      <h2>אלה שכבר<br/>דיברו איתה</h2>
    </div>
    <div class="testimonials-grid">
      {testimonials.map((t, i) => (
        <figure class:list={["testimonial-card", "reveal", i % 3 === 1 && "offset"]} style={`--delay: ${i * 0.1}s`}>
          <div class="review-header">
            <div class="review-avatar">{t.initials}</div>
            <div class="review-meta">
              <span class="review-name">{t.name}</span>
            </div>
            <div class="review-stars">{"★".repeat(t.stars)}</div>
          </div>
          <blockquote>{t.q}</blockquote>
          <div class="review-footer">
            <span class="review-type">{t.r}</span>
            <span class="review-date">{t.date}</span>
          </div>
        </figure>
      ))}
    </div>
  </section>

  <div class="divider"><div class="divider-star"></div></div>

  <!-- ═══════ 8. ACADEMY TEASER ═══════ -->
  <section class="academy-teaser" id="academy">
    <div class="academy-inner">
      <div class="academy-text reveal">
        <span class="section-label">לומדים את השפה</span>
        <h2>אקדמיית<br/>מכתובה</h2>
        <p>194 שיעורים חינמיים. עשרה קורסים. שלוש שפות. ללא רישום. ללא חיוב.</p>
        <a href="/academy" class="btn-primary" style="margin-top: 2rem;">כניסה לאקדמיה</a>
      </div>
      <div class="academy-visual reveal" style="--delay: 0.2s">
        <div class="academy-cards">
          <div class="academy-card a1"><img src={img.theCards} alt="טארוט" loading="lazy" /><span>טארוט · 30</span></div>
          <div class="academy-card a2"><img src={img.studyingCup} alt="קפה" loading="lazy" /><span>קפה · 20</span></div>
          <div class="academy-card a3"><img src={img.lookingAtMoon} alt="אסטרולוגיה" loading="lazy" /><span>אסטרולוגיה · 25</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ 9. FINAL CTA ═══════ -->
  <section class="final-cta">
    <div class="cta-bg">
      <img src={img.silhouette} alt="" loading="lazy" />
    </div>
    <div class="cta-content reveal">
      <div class="cta-icon">
        <Icon name="eye" size={36} stroke="#d4a574" />
      </div>
      <h2>מה שנכתב<br/>מחכה לך</h2>
