---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Hero        from "@/components/sections/Hero.astro";
import Traditions  from "@/components/sections/Traditions.astro";
import Showcase    from "@/components/sections/Showcase.astro";
import HowItWorks  from "@/components/sections/HowItWorks.astro";
import Manifesto   from "@/components/sections/Manifesto.astro";
import Voices      from "@/components/sections/Voices.astro";
import FAQ         from "@/components/sections/FAQ.astro";
import FinalCTA    from "@/components/sections/FinalCTA.astro";
import "@/styles/global.css";

const CDN = "https://cdn.maktuba.app";
const heroWide = `${CDN}/img/21_hero_wide.webp`;
const mark     = `${CDN}/brand/mark-512.webp?v=2`;
---

<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#060410" />
  <title>מכתובה — קריאת קפה, טארוט, כף יד ואסטרולוגיה עם AI</title>
  <meta name="description" content="סבתא עתיקה שקוראת את הקפה, הכף, הכוכבים והנשמה שלך. למעלה מ-200 סוגי קריאות AI. הקריאה הראשונה — אצלי." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,400&family=Frank+Ruhl+Libre:wght@300;400;500;700;900&family=Heebo:wght@300;400;500;700&display=swap" rel="stylesheet" />
</head>

<body>
  <!-- ═══════ CURTAIN ═══════ -->
  <div id="curtain" aria-hidden="true">
    <img src={heroWide} alt="" class="curtain-eyes" />
    <div class="curtain-vignette"></div>
    <img src={mark} alt="" class="curtain-mark" />
    <div class="curtain-wordmark">מַכְתּוּבָה</div>
  </div>
  <script is:inline>
    try {
      if (sessionStorage.getItem('maktuba:curtain') === '1') {
        var c = document.getElementById('curtain');
        if (c) c.remove();
      } else {
        sessionStorage.setItem('maktuba:curtain', '1');
      }
    } catch (e) {}
  </script>

  <Header lang="he" />

  <main>
    <Hero />
    <Traditions />
    <Showcase />
    <HowItWorks />
    <Manifesto />
    <Voices />
    <FAQ />
    <FinalCTA />
  </main>

  <Footer lang="he" />

  <script is:inline>
    // Subtle parallax on hero, desktop only (brandbook forbids on mobile)
    const heroBg = document.querySelector('.hero .hero-bg img');
    if (heroBg && window.innerWidth > 768 && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      let ticking = false;
      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            heroBg.style.transform = `scale(1.08) translateY(${window.scrollY * 0.18}px)`;
            ticking = false;
          });
          ticking = true;
        }
      }, { passive: true });
    }
  </script>
</body>
</html>

<style is:global>
  :root {
    --ink: #0a0612;
    --void: #060410;
    --gold: #d4a574;
    --gold-hi: #f1d694;
    --gold-light: #f4e4a0;
    --gold-dark: #b8860b;
    --gold-logo: #c9a96e;
    --gold-soft: rgba(212,175,55,0.08);
    --parchment: #ebe3d3;
    --muted: #8a7a60;
    --border: #1e1535;
    --glow: rgba(212,165,116,0.15);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'Heebo', sans-serif;
    background: var(--ink);
    color: var(--parchment);
    overflow-x: hidden;
    font-size: 17px;
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
  }

  /* Grain — environment breathes */
  body::after {
    content: '';
    position: fixed; inset: 0; z-index: 9999;
    pointer-events: none;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='300' height='300'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/></filter><rect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/></svg>");
  }

  /* ═══ CURTAIN ═══ */
  #curtain {
    position: fixed; inset: 0; z-index: 10000;
    background: var(--ink);
    display: flex; align-items: center; justify-content: center;
    transition: opacity 0.8s ease, visibility 0.8s;
  }
  .curtain-eyes {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center 30%;
    filter: brightness(0.7) contrast(1.2) saturate(0.8);
    transform: scale(1.1);
    transition: transform 1.5s cubic-bezier(0.16, 1, 0.3, 1), filter 1.5s;
  }
  .curtain-vignette {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at center, transparent 30%, var(--ink) 75%);
  }
  .curtain-mark {
    position: absolute;
    width: clamp(140px, 22vw, 260px); height: auto;
    margin-bottom: clamp(12rem, 24vw, 18rem);
    opacity: 0;
    filter: drop-shadow(0 0 40px rgba(212, 165, 116, 0.35));
    animation: curtainMark 3s 0.2s ease forwards;
  }
  @keyframes curtainMark {
    0%   { opacity: 0; transform: scale(0.85); }
    60%  { opacity: 1; transform: scale(1); }
    100% { opacity: 1; }
  }
  .curtain-wordmark {
    position: absolute;
    margin-top: clamp(6rem, 14vw, 12rem);
    font-family: 'Frank Ruhl Libre', serif;
    font-size: clamp(3rem, 11vw, 9rem);
    font-weight: 900;
    color: var(--gold);
    text-shadow: 0 0 80px rgba(212,165,116,0.5), 0 0 160px rgba(212,165,116,0.2);
    opacity: 0;
    animation: curtainWordmark 3s 0.9s ease forwards;
  }
  @keyframes curtainWordmark {
    0%   { opacity: 0; transform: scale(0.9); filter: blur(10px); }
    50%  { opacity: 1; transform: scale(1); filter: blur(0); }
    100% { opacity: 1; }
  }
  #curtain.lift { pointer-events: none; }
  #curtain.lift .curtain-eyes { transform: scale(1.3); filter: brightness(0.3) contrast(1.4) saturate(0); }
  #curtain.lift .curtain-wordmark, #curtain.lift .curtain-mark { opacity: 0 !important; transition: opacity 0.5s; }
  #curtain.gone { opacity: 0; visibility: hidden; }

  /* Reduced motion respect */
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after { animation: none !important; transition: none !important; }
    html { scroll-behavior: auto; }
  }
</style>
