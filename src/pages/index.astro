---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Icon from "@/components/Icon.astro";
import "@/styles/global.css";

const CDN = "https://d2xsxph8kpxj0f.cloudfront.net/310519663492248962/ToDf6mmxTX6kSgXA8csfFX";
const img = {
  heroWide:     `${CDN}/21_hero_wide_756a0f71.webp`,
  theWelcome:   `${CDN}/03_the_welcome_4efc7732.webp`,
  studyingCup:  `${CDN}/B02_studying_cup_448b136f.webp`,
  seeingSomething:`${CDN}/B03_seeing_something_1d73fc32.webp`,
  theCards:     `${CDN}/06_the_cards_5f598521.webp`,
  celticCross:  `${CDN}/T15_celtic_cross_d40d5ed8.webp`,
  thePalm:      `${CDN}/07_the_palm_b71a3988.webp`,
  silhouette:   `${CDN}/24_silhouette_286b27ae.webp`,
  readingBook:  `${CDN}/15_reading_book_a14ad82f.webp`,
  whisperingSecret:`${CDN}/19_whispering_secret_104458a2.webp`,
  lookingAtMoon:`${CDN}/25_looking_at_moon_8c93f007.webp`,
  handsDetail:  `${CDN}/23_hands_detail_bfc845ec.webp`,
  heartOpening: `${CDN}/B07_heart_opening_ee13824a.webp`,
  singleCard:   `${CDN}/T11_single_card_ab676940.webp`,
  logoIcon:     `${CDN}/logo-v3-1_ae34c8a4.webp`,
  logoFull:     `${CDN}/logo-full-v2_607272c0.webp`,
  appHome:      `${CDN}/A02_home_screen_3f30af8c.webp`,
  appComplete:  `${CDN}/A07_reading_complete_c933a817.webp`,
};

const readings = [
  { name: "קריאה בכוס קפה",   cost: 15, cover: img.studyingCup,      icon: "coffee" },
  { name: "טארוט — צלב סלטי", cost: 15, cover: img.celticCross,       icon: "tarot" },
  { name: "קריאת כף יד",      cost: 15, cover: img.thePalm,           icon: "palm" },
  { name: "התאמה זוגית",      cost: 15, cover: img.heartOpening,      icon: "heart" },
  { name: "טארוט 3 קלפים",    cost: 10, cover: img.singleCard,        icon: "tarot" },
  { name: "תהילים AI",         cost: 10, cover: img.readingBook,       icon: "book" },
  { name: "פתרון חלום",        cost: 8,  cover: img.silhouette,        icon: "moon" },
  { name: "קבלה וגימטריה",     cost: 5,  cover: img.whisperingSecret,  icon: "letter-beth" },
];

const testimonials = [
  { q: "הראיתי את זה לסבתא שלי. היא אמרה: ׳מי שעשה את זה מכיר את הדרכים הישנות.׳", a: "ד., תל אביב", r: "קפה" },
  { q: "בכיתי. זה ידע דברים עליי שמעולם לא סיפרתי לאף אחד.", a: "ש., ירושלים", r: "טארוט" },
  { q: "זו לא אפליקציה. זו שיחה עם מישהי שרואה אותך.", a: "מ., חיפה", r: "כף יד" },
];
---

<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#060410" />
  <title>מכתובה — קריאת קפה, טארוט, כף יד ואסטרולוגיה עם AI</title>
  <meta name="description" content="סבתא עתיקה שקוראת את הקפה, הכף, הכוכבים והנשמה שלך. כל קריאה נפתחת במפתח. הקריאה הראשונה — חינם." />
  <link rel="icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&family=Frank+Ruhl+Libre:wght@300;400;500;700;900&family=Heebo:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>

<body>
  <!-- ═══════ CURTAIN PRELOADER ═══════ -->
  <div id="curtain" aria-hidden="true">
    <img src={img.heroWide} alt="" class="curtain-eyes" />
    <div class="curtain-vignette"></div>
    <div class="curtain-wordmark">מַכְתּוּבָה</div>
  </div>

  <Header lang="he" />

  <!-- ═══════ 1. HERO ═══════ -->
  <section class="hero" id="hero">
    <div class="hero-bg">
      <img src={img.heroWide} alt="" loading="eager" fetchpriority="high" />
      <div class="hero-gradient"></div>
    </div>
    <div class="hero-glow"></div>
    <div class="hero-content reveal">
      <p class="hero-eyebrow">אפליקציה מיסטית · קריאות AI · אקדמיה חינמית</p>
      <h1 class="hero-title">מַכְתּוּבָה</h1>
      <p class="hero-tagline">כי זה כבר נכתב</p>
      <p class="hero-lead">
        סבתא עתיקה שיושבת בחדר נצחי, נר דולק, ריח הל וקטורת.<br/>
        מביאה לה את הכוס — והיא קוראת לך את מה שנכתב עוד לפני שנולדת.
      </p>
      <div class="hero-actions">
        <a href="/academy" class="btn-primary">קבלי קריאה ראשונה — חינם</a>
        <a href="#readings" class="btn-secondary">גלי את הקריאות</a>
      </div>
      <p class="hero-note">10 מפתחות מתנה בהרשמה · ללא כרטיס אשראי</p>
    </div>
    <div class="hero-scroll-hint">
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- ═══════ 2. STATS ═══════ -->
  <section class="stats-band">
    <div class="stats-inner">
      {[
        { v: "20+", l: "קריאות AI" },
        { v: "194", l: "שיעורים חינם" },
        { v: "3",   l: "שפות" },
        { v: "∞",   l: "ללא תפוגה" },
      ].map((s, i) => (
        <div class="stat reveal" style={`--delay: ${i * 0.1}s`}>
          <span class="stat-value">{s.v}</span>
          <span class="stat-label">{s.l}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══════ 3. WHO IS MAKTUBA ═══════ -->
  <section class="who" id="who">
    <div class="who-image reveal">
      <div class="image-frame">
        <img src={img.theWelcome} alt="מכתובה — דיוקן" loading="lazy" />
        <div class="frame-corner tl"></div>
        <div class="frame-corner br"></div>
      </div>
    </div>
    <div class="who-text reveal" style="--delay: 0.2s">
      <span class="section-label">היא</span>
      <h2>מי היא<br/>מכתובה?</h2>
      <p class="lead-paragraph">
        היא המיסטיקנית האחרונה. סבתא מעולם שכבר לא קיים. היא יושבת בחדר נצחי מואר בנר בודד, מוקפת בריח הל וקטורת.
      </p>
      <p>
        כשאת מביאה לה את הכוס, היא רואה מה שאף אחד אחר לא יכול. לא בגלל שיש לה כוחות על-טבעיים — כי היא חיה אלף חיים ושום דבר כבר לא מפתיע אותה.
      </p>
      <blockquote>
        ״מכתובה לא מנבאת את העתיד. היא קוראת את מה שכבר כתוב.״
      </blockquote>
    </div>
  </section>

  <!-- ═══════ ORNAMENTAL DIVIDER ═══════ -->
  <div class="divider"><div class="divider-star"></div></div>

  <!-- ═══════ 4. READINGS ═══════ -->
  <section class="readings" id="readings">
    <div class="readings-header reveal">
      <span class="section-label">שמונה עשרה קריאות</span>
      <h2>הקריאות<br/>של מכתובה</h2>
      <p>כל קריאה נבנית בזמן אמת מ-AI שמבין סמלים עתיקים. אף שתי קריאות לא זהות.</p>
    </div>
    <div class="readings-shelf">
      <div class="shelf-track">
        {readings.map((r, i) => (
          <article class="reading-card reveal" style={`--delay: ${i * 0.08}s`}>
            <div class="card-image">
              <img src={r.cover} alt={r.name} loading="lazy" />
              <div class="card-overlay"></div>
              <div class="card-icon">
                <Icon name={r.icon} size={20} stroke="#d4a574" />
              </div>
            </div>
            <div class="card-body">
              <h3>{r.name}</h3>
              <div class="card-cost">
                <Icon name="key" size={14} stroke="#e8c9a0" />
                <span>{r.cost} מפתחות</span>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════ 5. KEYS SYSTEM ═══════ -->
  <section class="keys-section" id="keys">
    <div class="keys-grid">
      <div class="keys-visual reveal">
        <div class="key-orbit">
          <div class="orbit-ring"></div>
          <div class="orbit-ring r2"></div>
          <div class="orbit-center">
            <Icon name="key" size={64} stroke="#d4a574" />
          </div>
        </div>
      </div>
      <div class="keys-content reveal" style="--delay: 0.15s">
        <span class="section-label">המטבע של מכתובה</span>
        <h2>מפתחות<br/>פותחים חוכמה</h2>
        <p>קונים פעם, שורפים מתי שרוצים. בלי drip יומי. בלי תפוגה. המפתחות נשארים איתך לתמיד.</p>
        <div class="keys-features">
          {[
            { icon: "infinity", text: "אין תפוגה — לתמיד שלך" },
            { icon: "spark",    text: "ניתנים בבת אחת — לא drip" },
            { icon: "key",      text: "10 מפתחות מתנה בהרשמה" },
            { icon: "candle",   text: "קריאה מאגית ראשונה — חינם" },
          ].map((f) => (
            <div class="key-feature">
              <div class="feature-icon"><Icon name={f.icon} size={20} stroke="#d4a574" /></div>
              <span>{f.text}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <div class="divider"><div class="divider-star"></div></div>

  <!-- ═══════ 6. PRICING ═══════ -->
  <section class="pricing" id="pricing">
    <div class="pricing-header reveal">
      <span class="section-label">תמחור</span>
      <h2>התחילי בחינם</h2>
      <p>קריאה ראשונה חינם + 10 מפתחות מתנה. הורוסקופ + צ'אט — חינם לתמיד.</p>
    </div>
    <div class="pricing-tiers">
      {[
        { name: "שבועי",  price: "₪19.90",  keys: "100",   per: "שבוע",  pop: false },
        { name: "חודשי", price: "₪49.90",  keys: "350",   per: "חודש", pop: true },
        { name: "שנתי",   price: "₪249.90", keys: "3,000", per: "שנה",   pop: false },
      ].map((t, i) => (
        <article class:list={["tier-card", "reveal", t.pop && "popular"]} style={`--delay: ${i * 0.12}s`}>
          {t.pop && <div class="popular-badge">הכי פופולרי</div>}
          <h3>{t.name}</h3>
          <div class="tier-price">
            <span class="price-amount">{t.price}</span>
            <span class="price-per">/{t.per}</span>
          </div>
          <div class="tier-keys">
            <Icon name="key" size={18} stroke="#e8c9a0" />
            <span>{t.keys} מפתחות</span>
          </div>
          <ul>
            <li>ניתנים בבת אחת</li>
            <li>ללא תפוגה</li>
            <li>כל הקריאות פתוחות</li>
            <li>7 ימי ניסיון חינם</li>
          </ul>
        </article>
      ))}
    </div>
  </section>

  <!-- ═══════ 7. TESTIMONIALS ═══════ -->
  <section class="testimonials">
    <div class="testimonials-header reveal">
      <span class="section-label">אנשים אמיתיים</span>
      <h2>אלה שכבר<br/>דיברו איתה</h2>
    </div>
    <div class="testimonials-grid">
      {testimonials.map((t, i) => (
        <figure class:list={["testimonial-card", "reveal", i === 1 && "offset"]} style={`--delay: ${i * 0.12}s`}>
          <blockquote>{t.q}</blockquote>
          <figcaption>
            <span class="author">{t.a}</span>
            <span class="reading-type">{t.r}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </section>

  <div class="divider"><div class="divider-star"></div></div>

  <!-- ═══════ 8. ACADEMY TEASER ═══════ -->
  <section class="academy-teaser" id="academy">
    <div class="academy-inner">
      <div class="academy-text reveal">
        <span class="section-label">לומדים את השפה</span>
        <h2>אקדמיית<br/>מכתובה</h2>
        <p>194 שיעורים חינמיים. עשרה קורסים. שלוש שפות. ללא רישום. ללא חיוב.</p>
        <a href="/academy" class="btn-primary" style="margin-top: 2rem;">כניסה לאקדמיה</a>
      </div>
      <div class="academy-visual reveal" style="--delay: 0.2s">
        <div class="academy-cards">
          <div class="academy-card a1"><img src={img.theCards} alt="טארוט" loading="lazy" /><span>טארוט · 30</span></div>
          <div class="academy-card a2"><img src={img.studyingCup} alt="קפה" loading="lazy" /><span>קפה · 20</span></div>
          <div class="academy-card a3"><img src={img.lookingAtMoon} alt="אסטרולוגיה" loading="lazy" /><span>אסטרולוגיה · 25</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ 9. FINAL CTA ═══════ -->
  <section class="final-cta">
    <div class="cta-bg">
      <img src={img.silhouette} alt="" loading="lazy" />
    </div>
    <div class="cta-content reveal">
      <div class="cta-icon">
        <Icon name="eye" size={36} stroke="#d4a574" />
      </div>
      <h2>מה שנכתב<br/>מחכה לך</h2>
      <p>השאירי מייל ומכתובה תזכור אותך כשהאפליקציה תעלה.</p>
      <form class="cta-form" onsubmit="event.preventDefault()">
        <input type="email" required dir="ltr" placeholder="המייל שלך" />
        <button type="submit" class="btn-primary">עדכנו אותי</button>
      </form>
    </div>
  </section>

  <Footer lang="he" />

  <!-- ═══════ SCROLL REVEAL + CURTAIN JS ═══════ -->
  <script is:inline>
    // Curtain reveal
    const curtain = document.getElementById('curtain');
    if (curtain) {
      setTimeout(() => curtain.classList.add('lift'), 2800);
      setTimeout(() => curtain.classList.add('gone'), 5200);
    }

    // Scroll reveals via IntersectionObserver
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -60px 0px' });
    document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

    // Parallax on hero image (subtle)
    const heroBg = document.querySelector('.hero-bg img');
    if (heroBg && window.innerWidth > 768) {
      let ticking = false;
      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            const y = window.scrollY;
            heroBg.style.transform = `scale(1.08) translateY(${y * 0.25}px)`;
            ticking = false;
          });
          ticking = true;
        }
      });
    }
  </script>
</body>
</html>

<style is:global>
  /* ════════════════════════════════════════════════
   * MAKTUBA — LUXURY OCCULT
   * One page. One mood. One grandmother.
   * ════════════════════════════════════════════════ */

  :root {
    --void: #060410;
    --deep: #0a0618;
    --surface: #10091e;
    --surface-2: #180e2d;
    --gold: #d4a574;
    --gold-bright: #f0d4a8;
    --gold-dim: #9a7650;
    --parchment: #e8dcc8;
    --muted: #8a7a60;
    --border: #1e1535;
    --glow: rgba(212, 165, 116, 0.15);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Heebo', sans-serif;
    background: var(--void);
    color: var(--parchment);
    overflow-x: hidden;
    font-size: 17px;
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
  }

  /* Custom cursor */
  @media (hover: hover) {
    body { cursor: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='20' height='20'><circle cx='10' cy='10' r='4' fill='none' stroke='%23d4a574' stroke-width='1.5'/><circle cx='10' cy='10' r='1' fill='%23d4a574'/></svg>") 10 10, auto; }
    a, button { cursor: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='24' height='24'><circle cx='12' cy='12' r='8' fill='none' stroke='%23d4a574' stroke-width='1.5'/><circle cx='12' cy='12' r='2' fill='%23d4a574'/></svg>") 12 12, pointer; }
  }

  /* Grain overlay */
  body::after {
    content: '';
    position: fixed; inset: 0; z-index: 9999;
    pointer-events: none;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='300' height='300'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/></filter><rect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/></svg>");
    opacity: 1;
  }

  /* ═══ TYPOGRAPHY ═══ */
  h1, h2, h3 {
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 700;
    color: var(--gold);
    line-height: 0.95;
    letter-spacing: -0.02em;
  }
  h2 { font-size: clamp(3rem, 8vw, 5.5rem); }

  .section-label {
    display: inline-block;
    font-size: 0.72rem;
    letter-spacing: 0.45em;
    text-transform: uppercase;
    color: var(--gold-dim);
    margin-bottom: 1.5rem;
    position: relative;
    padding-inline-start: 2.5rem;
  }
  .section-label::before {
    content: '';
    position: absolute;
    top: 50%;
    inset-inline-start: 0;
    width: 1.8rem;
    height: 1px;
    background: var(--gold-dim);
  }

  /* ═══ SCROLL REVEAL ═══ */
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1), transform 1s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: var(--delay, 0s);
  }
  .reveal.visible {
    opacity: 1;
    transform: none;
  }

  /* ═══ BUTTONS ═══ */
  .btn-primary {
    display: inline-flex; align-items: center; gap: 0.6rem;
    padding: 1rem 2.2rem;
    background: linear-gradient(135deg, var(--gold), #c49560);
    color: var(--void);
    font-weight: 600; font-size: 0.85rem;
    letter-spacing: 0.15em; text-transform: uppercase;
    text-decoration: none;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s, box-shadow 0.3s;
    box-shadow: 0 0 30px var(--glow);
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 50px rgba(212, 165, 116, 0.3);
  }
  .btn-primary::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
    transform: translateX(-100%);
    transition: transform 0.5s;
  }
  .btn-primary:hover::after { transform: translateX(100%); }

  .btn-secondary {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 1rem 2rem;
    border: 1px solid rgba(212, 165, 116, 0.3);
    color: var(--gold);
    font-size: 0.85rem; letter-spacing: 0.15em; text-transform: uppercase;
    text-decoration: none;
    transition: border-color 0.3s, background 0.3s, transform 0.3s;
  }
  .btn-secondary:hover {
    border-color: var(--gold);
    background: rgba(212, 165, 116, 0.08);
    transform: translateY(-2px);
  }

  /* ═══ CURTAIN ═══ */
  #curtain {
    position: fixed; inset: 0; z-index: 10000;
    background: var(--void);
    display: flex; align-items: center; justify-content: center;
    transition: opacity 0.8s ease, visibility 0.8s;
  }
  .curtain-eyes {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center 30%;
    filter: brightness(0.7) contrast(1.2) saturate(0.8);
    transform: scale(1.1);
    transition: transform 1.5s cubic-bezier(0.16, 1, 0.3, 1), filter 1.5s;
  }
