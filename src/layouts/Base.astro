---
import "@/styles/global.css";
export interface Props {
  title: string;
  description: string;
  keywords?: string[];
  canonical?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  lang?: "he" | "en" | "ar";
  dir?: "rtl" | "ltr";
  themeColor?: string;
}
const {
  title, description, keywords = [], canonical, ogImage = "/og-default.png",
  ogType = "website", jsonLd, lang = "he", dir = lang === "en" ? "ltr" : "rtl",
  themeColor = "#0a0612",
} = Astro.props;
const url = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const jsonLdArr = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const ogLocaleMap = { he: "he_IL", en: "en_US", ar: "ar_EG" };
const altLangs: Array<{code: string; href: string}> = [
  { code: "he", href: canonical ?? new URL(Astro.url.pathname.replace(/^\/(en|ar)\//, "/"), Astro.site).toString() },
  { code: "en", href: new URL("/en" + Astro.url.pathname.replace(/^\/(en|ar)/, ""), Astro.site).toString() },
  { code: "ar", href: new URL("/ar" + Astro.url.pathname.replace(/^\/(en|ar)/, ""), Astro.site).toString() },
];
---
<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content={themeColor} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(", ")} />}
    <link rel="canonical" href={url} />
    {altLangs.map(({code, href}) => (
      <link rel="alternate" hreflang={code} href={href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={altLangs[0].href} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Maktuba Academy" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:locale" content={ogLocaleMap[lang]} />
    {Object.entries(ogLocaleMap).filter(([k]) => k !== lang).map(([, v]) => (
      <meta property="og:locale:alternate" content={v} />
    ))}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    {jsonLdArr.map((ld) => (
      <script type="application/ld+json" set:html={JSON.stringify(ld)} />
    ))}
  </head>
  <body>
    <slot />
  </body>
</html>
